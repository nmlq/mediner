# use data folder by default
DEFAULT_MEDINER_FOLDER="data"
# input used in train and predict in docker compose
INPUT_JSON="${DEFAULT_MEDINER_FOLDER}/input.json"
# output used on predict in docker compose
OUTPUT_JSON="${DEFAULT_MEDINER_FOLDER}/output.json"
# model file used for train
MODEL_FILE="${DEFAULT_MEDINER_FOLDER}/model.pkl"
